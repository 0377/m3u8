# 解密脚本配置示例
# 复制为 decrypt.yaml 后按需修改

scripts_dir: scripts
external_timeout: 30s

rules:
  # 按域名 + METHOD 匹配
  - match:
      host: "*.example.com"
      method: SAMPLE-AES
    script: scripts/sample-aes.py

  # 仅覆盖 AES-128 的 Key Hook（key 二次派生）
  - match:
      method: AES-128
    script: scripts/custom-key.star
